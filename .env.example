# Server
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080

# Database
APP__DATABASE__URL=sqlite:rust-sso.db

# JWT
APP__JWT__SECRET=change-me-to-a-random-secret-at-least-32-chars
APP__JWT__EXPIRY=3600
APP__JWT__ISSUER=rust-sso

# Bcrypt
APP__BCRYPT__COST=12

# CORS (comma-separated origins, empty = allow all)
APP__CORS__ORIGINS=

# SMTP (for email verification codes)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Cloudflare Access (optional)
CF_ACCESS_TEAM=your-team-domain
